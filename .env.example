# =========================
# Core app (required)
# =========================
DATABASE_URL=postgresql://user:pass@localhost:5432/yendiin
SESSION_SECRET=change-me-session-secret
DEFAULT_TENANT=default
DEFAULT_PUBLIC_TENANT=default
APP_BASE_URL=http://localhost:8000

# =========================
# Auth
# =========================
GOOGLE_CLIENT_ID=
VITE_GOOGLE_CLIENT_ID=
MAGICLINK_SECRET=change-me-magiclink-secret
MAGICLINK_TTL_MINUTES=30

# =========================
# Email / notifications
# =========================
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=no-reply@yendiin.com
MAIL_FROM=no-reply@yendiin.com
EMAIL_CONFIRM_ENABLED=true
EMAIL_CONFIRM_MAX_ATTEMPTS=10
EMAIL_ATTACH_PDF=true
EMAIL_ATTACH_QR_PNG=false
EMAIL_MAX_QR_ATTACHMENTS=20
ORDER_EMAIL_LOG_TABLE=order_email_log

# =========================
# Uploads / CORS
# =========================
UPLOAD_DIR=/var/data/uploads
CORS_ALLOW_ORIGINS=http://localhost:5173,http://localhost:8000

# =========================
# Mercado Pago (platform + split/OAuth)
# =========================
MP_ACCESS_TOKEN=
MP_API_BASE=https://api.mercadopago.com
MP_WEBHOOK_SECRET=
MP_WEBHOOK_RESEND_EMAIL=0
MP_OAUTH_CLIENT_ID=
MP_OAUTH_CLIENT_SECRET=
MP_OAUTH_REDIRECT_URI=
MP_OAUTH_AUTH_URL=https://auth.mercadopago.com/authorization
MP_OAUTH_STATE_MAX_AGE_SECONDS=900
SERVICE_CHARGE_PCT=0.15
MIS_TICKETS_PATH=/#/mis-tickets

# Optional collector defaults by tenant:
# MP_COLLECTOR_ID_DEFAULT=
# MP_COLLECTOR_ID_<TENANT_UPPERCASE>=

# =========================
# Support AI (optional)
# =========================
SUPPORT_AI_ENABLED=false
SUPPORT_AI_MODEL=gpt-5-mini
SUPPORT_AI_TIMEOUT_S=45
SUPPORT_AI_STAFF_EMAILS=
OPENAI_API_KEY=
OPENAI_VECTOR_STORE_ID=

# =========================
# Campaigns / producer
# =========================
PRODUCER_MARKETING_ALLOW_HEADER_AUTH=0
CAMPAIGN_UNSUBSCRIBE_SECRET=change-me-campaign-secret
CAMPAIGN_BATCH_SIZE=100
CAMPAIGN_MAX_RECIPIENTS=5000

# =========================
# Branding / legal (backend + frontend fallback)
# =========================
BRAND_NAME=Yendiin
BRAND_SUPPORT_EMAIL=soporte@yendiin.com
BRAND_LEGAL_NAME=Yendiin SAS
BRAND_WEB_URL=https://yendiin.com
LEGAL_TERMS_URL=
LEGAL_PRIVACY_URL=

# Frontend Vite runtime/build defaults
VITE_BRAND_NAME=Yendiin
VITE_BRAND_SHORT_NAME=Yendiin
VITE_BRAND_HEADER_LABEL=Yendiin
VITE_BRAND_HERO_TITLE=Cartelera Viva
VITE_BRAND_HERO_SUBTITLE=Comprá tu ticket · QR antifraude · acceso rápido
VITE_BRAND_SUPPORT_EMAIL=soporte@yendiin.com
VITE_BRAND_SALES_EMAIL=ventas@yendiin.com
VITE_BRAND_INFO_EMAIL=info@yendiin.com
VITE_BRAND_WHATSAPP=
VITE_BRAND_INSTAGRAM_URL=
VITE_BRAND_TIKTOK_URL=
VITE_BRAND_X_URL=
VITE_BRAND_FOOTER_LEGAL_NAME=Yendiin SAS
VITE_BRAND_COPYRIGHT=Todos los derechos reservados
VITE_BRAND_PRODUCER_PANEL_LABEL=Productor
VITE_BRAND_ADMIN_PANEL_LABEL=Administrador

VITE_LEGAL_TERMS_URL=/static/legal/terminos-y-condiciones.pdf
VITE_LEGAL_PRIVACY_URL=/static/legal/politica-de-privacidad.pdf
VITE_LEGAL_REFUNDS_URL=/static/legal/politica-reembolsos.pdf
VITE_LEGAL_PRODUCER_TERMS_URL=/static/legal/terminos-y-condiciones-productor.pdf
VITE_FAQ_URL=/legal/faqs-ticketpro.html
VITE_FAQ_PRODUCER_URL=/legal/faqs-productor-ticketpro.html

VITE_FEATURE_PRODUCER_PANEL=true
VITE_FEATURE_GOOGLE_LOGIN=true
VITE_FEATURE_MAGIC_LINK_LOGIN=true
VITE_FEATURE_FEATURED_CAROUSEL=true
VITE_FEATURE_WHATSAPP_SHARE=true
VITE_FEATURE_SUPPORT_LINKS=true
VITE_FEATURE_BRANDED_ADMIN_LABELS=true
VITE_FEATURE_ALT_CHECKOUT_UX=false
VITE_FEATURE_ALT_PRODUCER_UI=false
VITE_FEATURE_ALT_STAFF_UI=false
