# ==========================================================
# BRANDING (FASE 1)
# Variables nuevas para desacoplar marca hardcodeada.
# Todas tienen fallback seguro en frontend/src/config/brand.js.
# ==========================================================

# Nombre principal de la marca (ej: TicketPro, MiMarca Entradas)
VITE_BRAND_NAME=TicketPro

# Nombre corto para espacios compactos (header/badges)
VITE_BRAND_SHORT_NAME=TicketPro

# Texto/logo textual del header
VITE_BRAND_HEADER_LABEL=TicketPro

# Hero home: título principal
VITE_BRAND_HERO_TITLE=Cartelera Viva

# Hero home: subtítulo / claim
VITE_BRAND_HERO_SUBTITLE=Comprá tu ticket · QR antifraude · acceso rápido

# Contacto: email soporte
VITE_BRAND_SUPPORT_EMAIL=soporte@ticketpro.com.ar

# Contacto: email ventas
VITE_BRAND_SALES_EMAIL=ventas@ticketpro.com.ar

# Contacto: email info/general
VITE_BRAND_INFO_EMAIL=info@ticketpro.com.ar

# Contacto WhatsApp (sólo números, con código de país)
VITE_BRAND_WHATSAPP=5492614167597

# Redes sociales
VITE_BRAND_INSTAGRAM_URL=#instagram
VITE_BRAND_TIKTOK_URL=#tiktok
VITE_BRAND_X_URL=#x

# Footer: razón social / entidad legal visible
VITE_BRAND_FOOTER_LEGAL_NAME=The Brain Lab SAS

# Footer: texto de copyright
VITE_BRAND_COPYRIGHT=Todos los derechos reservados

# Labels brandizados de paneles
VITE_BRAND_PRODUCER_PANEL_LABEL=Productor
VITE_BRAND_ADMIN_PANEL_LABEL=Administrador


# ==========================================================
# FEATURES (FASE 1)
# Toggles de UI seguros (true/false, 1/0, yes/no, on/off)
# Fallback por defecto: true.
# ==========================================================

# CTA / acceso visual al panel productor (footer)
VITE_FEATURE_PRODUCER_PANEL=true

# Mostrar login con Google
VITE_FEATURE_GOOGLE_LOGIN=true

# Mostrar login por magic link (email)
VITE_FEATURE_MAGIC_LINK_LOGIN=true

# Mostrar carrusel de destacados en home
VITE_FEATURE_FEATURED_CAROUSEL=true

# Habilitar acciones de compartir por WhatsApp
VITE_FEATURE_WHATSAPP_SHARE=true

# Mostrar bloque de links de soporte/contacto
VITE_FEATURE_SUPPORT_LINKS=true

# Usar labels de admin brandizados
VITE_FEATURE_BRANDED_ADMIN_LABELS=true
